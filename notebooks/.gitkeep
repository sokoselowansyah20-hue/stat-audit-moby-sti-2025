   "outputs": [],
   "source": [
    "# Data Collection\n",
    "\n",
    "This notebook collects repository data from the Pandas GitHub repository using the GitHub REST API.\n",
    "\n",
    "Repository:\n",
    "https://github.com/pandas-dev/pandas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6305324a",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "import requests\n",
    "import pandas as pd"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7842106e",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "owner = \"pandas-dev\"\n",
    "repo = \"pandas\"\n",
    "\n",
    "url = f\"https://api.github.com/repos/{owner}/{repo}/pulls?state=all&per_page=100\"\n",
    "\n",
    "response = requests.get(url)\n",
    "\n",
    "data = response.json()\n",
    "\n",
    "print(\"Total records:\", len(data))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "46219f66",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "df = pd.json_normalize(data)\n",
    "\n",
    "df.to_csv(\"../data/raw/pull_requests.csv\", index=False)\n",
    "\n",
    "df.head()"
   ]
  }
 ],
 "metadata": {
  "language_info": {
   "name": "python"
  }
 },
