import pandas as pd
from scipy import stats
import numpy as np

df = pd.read_csv("../data/raw/pull_requests.csv")

sample = np.random.randint(1,100,size=50)

mean = np.mean(sample)
std = np.std(sample, ddof=1)

ci = stats.t.interval(
    confidence=0.95,
    df=len(sample)-1,
    loc=mean,
    scale=std/np.sqrt(len(sample))
)

print(ci)
